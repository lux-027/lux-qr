generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model QrCode {
  id          String   @id @default(uuid())
  content     String
  contentType String   // text, image, video, file
  fileName    String?
  filePath    String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  
  @@index([id])
}
