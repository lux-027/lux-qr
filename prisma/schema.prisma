generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QrCode {
  id          String   @id @default(uuid())
  content     String
  contentType String   // text, image, video, file
  fileName    String?
  filePath    String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([id])
}
